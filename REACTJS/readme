// 1. let / const
const a = 10;
let b = 20;

// 2. Arrow function
const sum = (a, b) => a + b;

// 3. Destructuring
const user = { name: "A", age: 20 };
const { name, age } = user;

// 4. Spread
const arr1 = [1, 2];
const arr2 = [...arr1, 3];

// 5. Array methods
users.map(u => u.name);
users.filter(u => u.age > 18);
